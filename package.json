{
  "name": "claude-autopilot",
  "version": "0.1.0",
  "description": "Autonomous wrapper that runs Claude Code in an infinite loop on any repo until FINAL_GOAL.md is fully satisfied — zero human in the loop.",
  "type": "module",
  "bin": {
    "autopilot": "./bin/autopilot.js"
  },
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "prepare": "npm run build"
  },
  "files": [
    "dist",
    "bin",
    "README.md",
    "FINAL_GOAL.md",
    "ARCHITECTURE.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.1.0",
    "commander": "^12.1.0",
    "kleur": "^4.1.5"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.0"
  },
  "keywords": [
    "claude",
    "claude-code",
    "agent",
    "autopilot",
    "autonomous",
    "sdk"
  ],
  "license": "MIT"
}
